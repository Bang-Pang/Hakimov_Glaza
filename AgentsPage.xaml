<Page x:Class="Hakimov_Glaza.AgentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AgentsPage" FontFamily="Century Gothic"
      IsVisibleChanged="Page_IsVisibleChanged">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поиск + сортировка + фильтрация -->
        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBox Width="300" x:Name="TBoxSearch" TextChanged="TBoxSearch_TextChanged" Margin="0,0,10,0" />
            <ComboBox Width="150" x:Name="ComboSort" SelectionChanged="ComboSort_SelectionChanged" Margin="0,0,10,0">
                <ComboBoxItem Content="Без сортировки"/>
                <ComboBoxItem Content="Наименование (А-Я)"/>
                <ComboBoxItem Content="Наименование (Я-А)"/>
                <ComboBoxItem Content="Приоритет (возрастание)"/>
                <ComboBoxItem Content="Приоритет (убывание)"/>
                <ComboBoxItem Content="Скидка (возрастание)"/>
                <ComboBoxItem Content="Скидка (убывание)"/>
            </ComboBox>
            <ComboBox Width="150" x:Name="ComboFilter" SelectionChanged="ComboFilter_SelectionChanged" DisplayMemberPath="Title"/>
        </StackPanel>

        <!-- Кнопка добавления агента -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,0,10">
            <Button Content="Добавить агента" 
                    Click="AddButton_Click"/>
        </StackPanel>

        <!-- Список агентов -->
        <ListView x:Name="AgentListView" Grid.Row="2" HorizontalContentAlignment="Stretch">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" Width="100" Height="100" Stretch="Uniform">
                                <Image.Source>
                                    <Binding Path="Logo">
                                        <Binding.TargetNullValue>
                                            <ImageSource>/res/Глазки-save.png</ImageSource>
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </Image.Source>
                            </Image>

                            <StackPanel Grid.Column="1" Margin="10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding AgentType.Title}" FontSize="18"/>
                                    <TextBlock Text=" | " FontSize="18"/>
                                    <TextBlock Text="{Binding Title}" FontSize="18"/>
                                </StackPanel>
                                <TextBlock Text="{Binding TotalSales, StringFormat='{}{0} продаж за год'}" Margin="0,5"/>
                                <TextBlock Text="{Binding Phone}"/>
                                <TextBlock Text="{Binding Priority, StringFormat='Приоритетность: {0}'}" Margin="0,5"/>

                                <!-- Кнопки Редактировать и Удалить -->
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="Редактировать" Click="EditButton_Click" Width="110"/>
                                    <Button Content="Удалить" Click="DeleteButton_Click" Width="90" Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{Binding DiscountPercent, StringFormat='{}{0}%'}" 
                           FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Постраничный вывод -->
        <StackPanel Grid.Row="3" 
            Orientation="Horizontal" 
            HorizontalAlignment="Right" 
            VerticalAlignment="Bottom" 
            Margin="0,0,20,15">

            <Button x:Name="btnPrev" Content="◀" Width="35" Height="30" 
            Click="btnPrev_Click" Margin="0,0,8,0"/>

            <!-- Номера страниц без стиля кнопки -->
            <StackPanel x:Name="PagesPanel" Orientation="Horizontal" Margin="0,3,0,0"/>

            <Button x:Name="btnNext" Content="▶" Width="35" Height="30" 
            Click="btnNext_Click" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Page>