<Page x:Class="Hakimov_Glaza.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddEditPage" FontFamily="Century Gothic">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок + кнопка Назад -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,20">
            <Image Source="/res/Глазки-save.png" Width="50" Height="50" Margin="0,0,15,0"/>
            <TextBlock Text="Список агентов" FontSize="22" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button Content="Назад" 
                    HorizontalAlignment="Right" 
                    Click="BtnBack_Click" Foreground="White"/>
        </StackPanel>

        <!-- Основная форма в две колонки -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка -->
            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Строка 1: Наименование -->
                <TextBlock Text="Наименование" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,10,10"/>
                <TextBox x:Name="tbTitle" Grid.Row="0" Grid.Column="1" Margin="0,10,0,10" Height="30"/>

                <!-- Строка 2: Адрес -->
                <TextBlock Text="Адрес" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,10,10"/>
                <TextBox x:Name="tbAddress" Grid.Row="1" Grid.Column="1" Margin="0,10,0,10" Height="30"/>

                <!-- Строка 3: Директор -->
                <TextBlock Text="Директор" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,10,10"/>
                <TextBox x:Name="tbDirector" Grid.Row="2" Grid.Column="1" Margin="0,10,0,10" Height="30"/>

                <!-- Строка 4: Логотип -->
                <TextBlock Text="Логотип" Grid.Row="3" Grid.Column="0" VerticalAlignment="Top" Margin="0,10,10,10"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,10,0,10">
                    <Image x:Name="imgLogo" Width="100" Height="100" Stretch="UniformToFill" 
                           Source="/res/Глазки-save.png"/>
                    <Button Content="Выбрать..." Width="100" Height="30" Margin="0,10,0,0" 
                            Click="BtnChooseLogo_Click" Background="#B175EE" Foreground="White"/>
                </StackPanel>
            </Grid>

            <!-- Правая колонка -->
            <Grid Grid.Column="1" Margin="20,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Строка 1: Тип агента -->
                <TextBlock Text="Тип агента" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,10,10"/>
                <ComboBox x:Name="cmbAgentType" Grid.Row="0" Grid.Column="1" Margin="0,10,0,10" Height="30" DisplayMemberPath="Title"/>

                <!-- Строка 2: Приоритет -->
                <TextBlock Text="Приоритет" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,10,10"/>
                <TextBox x:Name="tbPriority" Grid.Row="1" Grid.Column="1" Margin="0,10,0,10" Height="30" Text="0"/>

                <!-- Строка 3: ИНН -->
                <TextBlock Text="ИНН" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,10,10"/>
                <TextBox x:Name="tbINN" Grid.Row="2" Grid.Column="1" Margin="0,10,0,10" Height="30"/>

                <!-- Строка 4: КПП -->
                <TextBlock Text="КПП" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,10,10"/>
                <TextBox x:Name="tbKPP" Grid.Row="3" Grid.Column="1" Margin="0,10,0,10" Height="30"/>

                <!-- Строка 5: Телефон и e-mail в одной строке -->
                <TextBlock Text="Телефон" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,10,10"/>
                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,10">
                    <TextBox x:Name="tbPhone" Width="180" Height="30" Margin="0,0,10,0"/>
                    <TextBlock Text="e-mail" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="tbEmail" Width="180" Height="30"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Кнопки внизу -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
            <Button Content="Изменить"  Click="BtnEdit_Click" Foreground="White"/>
            <Button Content="Сохранить" Click="BtnSave_Click" Foreground="White"/>
        </StackPanel>
    </Grid>
</Page>